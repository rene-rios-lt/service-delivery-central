@startuml position-update-flow
title Real-Time Position Update Flow

skinparam participant {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
}

participant "Simulator\n(VehicleWorker)" as Sim
participant "Backend API" as Backend
participant "VehiclePositionHub" as PosHub
participant "DispatchHub" as DispHub
participant "RequesterHub" as ReqHub
actor "Dispatcher(s)" as Dispatcher
actor "Requester" as Requester

note over Sim
  The simulator drives EVERY vehicle's position from its rep's
  backend job-state — including a truck a human has taken over
  (it navigates after the human accepts, then holds at the
  requester). Posted as the Simulator-role account.
end note

Sim -> Backend : POST /vehicles/{id}/position\n{ vehicleId, latitude, longitude }\nevery 3 seconds, all vehicles

Backend -> Backend : Persist position
Backend -> Backend : If rep has active Assigned request:\n  - Recalculate Haversine distance to requester\n  - If < 15 miles and EnRoute → Within15Miles\n  - Recalculate ETA

Backend -> PosHub : VehiclePositionUpdated\n{ repId, vehicleId, lat, lng, state }
PosHub -> Dispatcher : broadcast to all dispatchers

alt Rep has active Assigned request
    Backend -> DispHub : FleetPositionUpdate\n{ repId, lat, lng, state }
    DispHub -> Dispatcher : fleet map update

    Backend -> ReqHub : RepPositionUpdated\n{ lat, lng, etaMinutes, state }
    ReqHub -> Requester : live position + ETA update
end

@enduml

@startuml flow1-normal-request
title Flow 1 — Normal Request Lifecycle

skinparam participant {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

actor Requester
participant "Backend" as Backend
participant "RepHub" as RepHub
participant "RequesterHub" as ReqHub
participant "DispatchHub" as DispHub
actor "Service Rep" as Rep
actor Dispatcher

Requester -> Backend : POST /service-requests\n(GPS location + DTC selection)

Backend -> Backend : Run matching algorithm:\n1. Filter by dealer\n2. Filter by equipment (DTC match)\n3. Filter: Available only\n4. Exclude skipped reps\n5. Sort by Haversine distance\n6. Tiebreaker: longest Available

Backend -> RepHub : JobOfferReceived → Rep\n{ offerId, requesterName, tier, dtcTitle,\n  distanceMiles, etaMinutes, lat, lng }
RepHub -> Rep : job offer screen\n60-second countdown

alt Rep accepts
    Rep -> Backend : POST /job-offers/{id}/accept

    Backend -> ReqHub : RepAssigned → Requester\n{ repId, repName, etaMinutes, lat, lng }
    Backend -> DispHub : ServiceRequestAssigned + RepStateChanged → Dispatcher

    ReqHub -> Requester : tracking view\n(rep name, ETA, live map)
    DispHub -> Dispatcher : fleet map: rep marker → Blue (En Route)

    note over Backend, Dispatcher
      Position updates flow every 3 seconds (see position-update-flow diagram)
    end note

    Backend -> Backend : Haversine < 15 miles detected\nRep state → Within15Miles

    Requester <-- ReqHub : state = "Almost there" (Within15Miles)

    Rep -> Backend : POST /rep/arrive
    Backend -> Backend : Rep → OnSite\nRequest → InProgress

    Requester <-- ReqHub : RepArrived { repId, requestId }\n"Your technician has arrived" (OnSite)

    Rep -> Backend : POST /rep/complete
    Backend -> Backend : Rep → Available\nRequest → Completed

    Backend -> ReqHub : ServiceCompleted → Requester
    ReqHub -> Requester : "Your service is complete."
    DispHub -> Dispatcher : request removed from map\nrep marker → Green (Available)

else Rep declines or 60s expires
    Rep -> Backend : POST /job-offers/{id}/decline\n(or timeout)
    Backend -> Backend : Mark offer Declined/Expired\nRep permanently skipped for this job\nFind next best qualified rep
    note right : Repeats until accepted\nor all reps exhausted
end

@enduml

@startuml flow2-no-qualified-rep
title Flow 2 — No Qualified Rep Available

skinparam participant {
    BackgroundColor #EDE7F6
    BorderColor #4527A0
}

actor Requester
participant "Backend" as Backend
participant "RequesterHub" as ReqHub
participant "DispatchHub" as DispHub
actor "Dispatcher" as Dispatcher
actor "Service Rep" as Rep

Requester -> Backend : POST /service-requests\n(GPS location + DTC selection)

Backend -> Backend : Run matching algorithm:\n  no qualified rep found\n  (none available, all declined, or all expired)

Backend -> ReqHub : request stays Pending
ReqHub -> Requester : spinner: "finding your technician"

Backend -> DispHub : ServiceRequestPending → Dispatcher
DispHub -> Dispatcher : request appears in queue\n(no rep assigned yet)

note over Backend
  Backend monitors for rep state changes.
  Any rep transition to Available triggers
  re-run of matching for all Pending requests.
end note

alt A rep becomes Available
    Rep -> Backend : POST /rep/complete\n  or POST /vehicles/{id}/claim\n  (transitions rep → Available)

    Backend -> Backend : Re-run matching algorithm\nfor all Pending requests

    note right : Resumes Flow 1\nfrom job offer step
end

@enduml

@startuml flow3-priority-redirect
title Flow 3 — Priority Redirect

skinparam participant {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

actor "Gold Requester" as Gold
actor "Bronze Requester" as Bronze
participant "Backend" as Backend
participant "RepHub" as RepHub
participant "RequesterHub (Bronze)" as BronzeHub
participant "RequesterHub (Gold)" as GoldHub
participant "DispatchHub" as DispHub
actor "Dispatcher" as Dispatcher
actor "Rep (En Route)" as Rep

Gold -> Backend : POST /service-requests (Gold tier)

Backend -> DispHub : ServiceRequestPending → Dispatcher\n{ Gold badge, suggested match:\n  nearest En Route rep serving Bronze }
DispHub -> Dispatcher : Gold request in queue\nRedirect button enabled

Dispatcher -> Backend : POST /dispatcher/redirect\n{ repId, toRequestId: Gold request }

Backend -> Backend : Validate redirect eligibility:\n- Rep is EnRoute ✓\n- Gold > Bronze ✓\n- Cooldown? Gold overrides ✓\n- Not Within15Miles / OnSite ✓

Backend -> Backend : Bronze request → Pending\nRep hard-assigned to Gold request\nCooldown starts (5 min) for this rep

Backend -> RepHub : RedirectReceived → Rep\n{ newRequestId, Gold requester, dtcTitle,\n  distanceMiles, etaMinutes, lat, lng }
RepHub -> Rep : active job screen updates\nto new destination — no accept/decline

Backend -> Backend : Run matching algorithm\nfor displaced Bronze request

Backend -> GoldHub : RepAssigned → Gold Requester
GoldHub -> Gold : tracking view\n(rep heading to Gold location)

note over Backend
  Matching runs for Bronze:
  next best rep offered (Flow 1)
end note

Backend -> BronzeHub : RepRedirected → Bronze Requester\n(sent only after new rep accepts)\n{ oldRepName, newRepName, newEtaMinutes }
BronzeHub -> Bronze : "Our apologies, we needed to redirect\n[old rep]. [new rep] is heading your way."

@enduml

@startuml flow4-rep-offline
title Flow 4 — Rep Goes Offline Mid-Job

skinparam participant {
    BackgroundColor #FCE4EC
    BorderColor #880E4F
}

actor "Service Rep" as Rep
participant "Backend\n(RepHub)" as Backend
participant "DispatchHub" as DispHub
participant "RequesterHub" as ReqHub
actor Dispatcher
actor Requester

Rep ->x Backend : Connection lost\n(crash or logout)

Backend -> Backend : OnDisconnectedAsync triggered\nRep → Offline\nActive job → Pending\nVehicle stays Claimed

Backend -> DispHub : RepOfflineMidJob\n{ repId, requestId }
DispHub -> Dispatcher : alert: "[Rep] went offline — [DTC] request re-queued"\nrep marker disappears from map

Backend -> ReqHub : (requester returns to Pending state)
ReqHub -> Requester : spinner: "finding your technician"

Backend -> Backend : Run matching algorithm\nfor re-queued request\n(offered to any available rep — usually an automated one)

alt Automated (simulator) rep
    Backend -> Backend : Simulator reconciler resumes\nthat rep on its vehicle (normal loop)
else Human rep "goes home" (logout / heartbeat timeout)
    note right
      Rep parks; vehicle off-duty.
      Simulator does NOT re-assume a rep
      a human took over (sticky for the run).
    end note
    Dispatcher -> Backend : (optional) POST /vehicles/{id}/force-release
    Backend -> Backend : Vehicle → Unclaimed
end

@enduml

@startuml flow5-human-takeover
title Flow 5 — Human Takeover

skinparam participant {
    BackgroundColor #E0F2F1
    BorderColor #00695C
}

actor "Human Rep\n(device, logs in as rep3)" as Human
participant "Backend" as Backend
participant "Simulator" as Sim
participant "RepHub" as RepHub

Human -> Backend : GET idle vehicles\n(not en route / not on a job)
Backend -> Human : dropdown of idle vehicles

Human -> Backend : POST /vehicles/{V-002}/take-over
Backend -> Backend : release prior (simulator) claim on V-002\nend rep3's prior session\nclaim V-002 for rep3 (human)\nmark rep3 human-controlled

Sim -> Backend : GET fleet job-state (next tick)
Backend -> Sim : rep3 is human-controlled
Sim -> Sim : relinquish rep3; rebalance remaining\nautomated reps onto the freed vehicle

note over Human, RepHub
  From now on, for rep3's truck:
  • HUMAN decides — Accept/Decline, "I've Arrived", "Mark Complete"
  • SIMULATOR drives position from rep3's job-state
    (navigates to requester on Accept, then HOLDS)
end note

Backend -> RepHub : JobOfferReceived → rep3 (human's device)
RepHub -> Human : job offer screen (human taps Accept)
Sim -> Backend : POST /vehicles/V-002/position\n(navigating toward requester, then holding)
Human -> Backend : POST /rep/arrive , then /rep/complete

loop every ~15s while on duty
    Human -> Backend : heartbeat
end

note over Human, Backend
  On logout / heartbeat timeout → rep3 Offline, V-002 parks.
  Simulator does NOT re-assume (sticky).
end note

@enduml
