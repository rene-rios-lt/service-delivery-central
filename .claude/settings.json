{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(gh pr merge *)",
            "command": "/Users/rrios/dev/ServiceDelivery/scripts/utils/mark-story-complete.sh",
            "timeout": 15,
            "statusMessage": "Updating execution plan..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r \".tool_input.file_path // empty\"); case \"$f\" in */.claude/*) /Users/rrios/dev/ServiceDelivery/scripts/utils/validate-ai-system.sh --quiet 1>&2 || exit 2 ;; esac",
            "timeout": 15,
            "statusMessage": "Validating AI system..."
          }
        ]
      }
    ]
  }
}
